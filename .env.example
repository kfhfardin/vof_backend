# Voice of the Field — environment template
# Copy to .env.local for dev; never commit real values.

# --- Profile ---
DEPLOYMENT_PROFILE=local
ENVIRONMENT=dev

# --- Databases ---
DATABASE_URL=postgresql+asyncpg://votf:votf@localhost:5432/votf_app
BRAIN_DATABASE_URL=postgresql+asyncpg://votf:votf@localhost:5432/votf_brain
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO defaults for local) ---
S3_BUCKET=votf-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string-min-32-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

# --- AgentPhone ---
AGENTPHONE_API_KEY=
AGENTPHONE_WEBHOOK_SECRET=

# --- Supermemory ---
SUPERMEMORY_API_KEY=

# --- AgentMail (Phase 1 F6: email surface) ---
# Required for outbound email + inbound webhook (POST /api/v1/webhooks/agentmail/webhook).
# Empty → outbound email no-ops; inbound webhook returns 200 but doesn't process.
# Sign up: https://agentmail.to
AGENTMAIL_API_KEY=
# Optional custom email domain. Without it, AgentMail uses *.agentmail.to addresses.
# With it, each workspace gets <slug>@<your-domain>. MX records must point at AgentMail.
EMAIL_DOMAIN=

# --- Browser Use (Phase 1 F5: web verifier) — OPTIONAL ---
# Without it, the verifier falls back to an httpx + regex HTML stripper —
# good enough for the "did the page say this?" prompt per LLD speed variant.
# Wire the real Browser Use Cloud SDK when claim verification needs JS rendering.
# Sign up: https://browser-use.com
BROWSER_USE_API_KEY=

# --- LLM ---
# Two providers selected by LLM_PROVIDER. Pick ONE configuration block:
#
# ===== A. openai_compat — Anthropic direct or any OpenAI-compatible endpoint =====
# LLM_PROVIDER=openai_compat
# LLM_API_KEY=sk-ant-...                                    # bearer token
# LLM_BASE_URL=https://api.anthropic.com/v1/openai
# LLM_DEFAULT_MODEL=claude-sonnet-4-6                       # orchestrator hot path
# LLM_MODEL=claude-haiku-4-5                                # smoke probe + cheaper skills
#
# ===== B. bedrock — AWS Bedrock invoke_model (native Anthropic Messages API) =====
# LLM_PROVIDER=bedrock
# ANTHROPIC_API_KEY=<Bedrock long-term API key>             # surfaced to boto3 as AWS_BEARER_TOKEN_BEDROCK
# AWS_REGION=us-east-1                                      # must match where the key is scoped
# LLM_DEFAULT_MODEL=us.anthropic.claude-sonnet-4-6          # cross-region inference profile id
# LLM_MODEL=us.anthropic.claude-sonnet-4-6                  # smoke probe (use same profile)
#
# Plain Anthropic ids like `anthropic.claude-sonnet-4-6` raise
# ValidationException on Bedrock — on-demand throughput requires inference
# profile ids (prefixed with the region/global, e.g. `us.`).

ANTHROPIC_API_KEY=
LLM_PROVIDER=openai_compat
LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com/v1/openai
LLM_DEFAULT_MODEL=claude-sonnet-4-6
# LLM_MODEL is read by the smoke probe (stable test model, independent of skill pins).
LLM_MODEL=claude-haiku-4-5
# AWS_REGION is only read when LLM_PROVIDER=bedrock.
AWS_REGION=us-east-1

# --- Public URLs / CORS ---
PUBLIC_BASE_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Observability ---
LOG_LEVEL=INFO
OTEL_EXPORTER_ENDPOINT=

# --- Smoke probe test inputs (only needed when running smoke against AP) ---
SMOKE_AGENTPHONE_TEST_AGENT_ID=
SMOKE_AGENTPHONE_TEST_NUMBER_ID=
SMOKE_AGENTPHONE_TEST_CONVERSATION_ID=
SMOKE_AGENTPHONE_TEST_TO_NUMBER=
